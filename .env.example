# 可选：显式指定数据库后端（supabase | postgres | sqlite）
# 不填时按以下顺序自动选择：
# 1) Supabase 环境完整 -> supabase
# 2) 直连 Postgres 环境完整 -> postgres
# 3) 否则回退到 SQLite
DATABASE_PROVIDER=

# Supabase 数据库配置（仅在使用 Supabase 时填写；保留为空即可避免误选到 Supabase）
SUPABASE_URL=
# Supabase 匿名访问 Key（公开链路 / SSR 客户端使用）
SUPABASE_PUBLISHABLE_OR_ANON_KEY=
# Service Role Key（服务端使用，绕过 RLS，切勿暴露到客户端）
SUPABASE_SERVICE_ROLE_KEY=

# 可选：直连 Postgres（DATABASE_PROVIDER=postgres 时至少填写一个）
DATABASE_URL=
POSTGRES_URL=
POSTGRES_PRISMA_URL=
# 兼容 Supabase 直连 URL / 既有自动迁移能力
SUPABASE_DB_URL=

# 可选：本地 SQLite 文件路径；默认回退到 .sisyphus/local-data/app.db
SQLITE_DATABASE_PATH=.sisyphus/local-data/app.db
# 可选：托管主备 bootstrap store 路径；默认 .sisyphus/local-data/storage-bootstrap.db
STORAGE_BOOTSTRAP_SQLITE_PATH=.sisyphus/local-data/storage-bootstrap.db

# 后台登录 session 签名密钥；若未配置且环境中存在 SUPABASE_SERVICE_ROLE_KEY，则会回退使用它
# 对 SQLite / Postgres 部署，建议始终显式填写
ADMIN_SESSION_SECRET=your-admin-session-secret
# Turnstile 只有在站点 Key 和 Secret 同时存在时才会启用
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# 默认使用 public，如需非默认 schema 请显式填写
SUPABASE_DB_SCHEMA=public

# 本地开发通常使用 development；容器 / 线上环境使用 production
NODE_ENV=development
# 轮询间隔(秒)
CHECK_POLL_INTERVAL_SECONDS=60
# 历史数据保留天数(范围 7-365)
HISTORY_RETENTION_DAYS=30
# 官方状态检查间隔（默认 300 秒）
OFFICIAL_STATUS_CHECK_INTERVAL_SECONDS=300
# 最大请求并发数
CHECK_CONCURRENCY=5
